# DeepSeek API
DEEPSEEK_API_KEY=sk-your-key-here

# Path to cloned target repo (Element Android)
#   git clone https://github.com/element-hq/element-android.git
TARGET_REPO_PATH=/absolute/path/to/element-android

# --- Optional overrides (defaults shown) ---
# DEEPSEEK_MODEL=deepseek-v4-pro
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# EMBEDDING_MODEL=intfloat/multilingual-e5-small
# CHROMA_PATH=./.chroma
# CHROMA_COLLECTION=element_docs
# METRICS_PATH=./metrics.jsonl
# REQUEST_TIMEOUT=60
# TARGET_DEFAULT_BRANCH=develop

# --- Support assistant (Day 33) ---
# SUPPORT_CHROMA_COLLECTION=support_kb
