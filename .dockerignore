# Keep the build context small and secrets out of the image.
.git
.venv
venv
__pycache__
*.pyc
.pytest_cache
*.egg-info
codeassistant.egg-info

# Secrets and local state — provided at runtime via env_file / volumes.
.env
.chroma
metrics.jsonl

# Docs / eval not needed at runtime.
docs
eval
.superpowers
.claude
